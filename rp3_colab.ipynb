      "source": [
        "#@title Run the prediction\n",
        "\n",
        "import torch\n",
        "\n",
        "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "print(f\"Using device: {device}\")\n",
        "\n",
        "m = m.to(device=device)\n",
        "scores_map = dict()\n",
        "for b in batches():\n",
        "    scores_map |= m.predict(b, device=device)\n",
        "print(\"Prediction complete!\")\n"
      ]
    },
