        "#@title Install the dependencies and download the checkpoint\n",
        "! pip install torch torchvision\n",
        "! pip install RP3Net --no-deps\n",
        "\n",
        "import urllib.request, ssl\n",
        "\n",
        "url = \"https://ftp.ebi.ac.uk/pub/software/RP3Net/v0.1/checkpoints/rp3net_v0.1_d.ckpt\"\n",
        "ctx = ssl.create_default_context()\n",
        "ctx.check_hostname = False\n",
        "ctx.verify_mode = ssl.CERT_NONE\n",
        "\n",
        "with urllib.request.urlopen(url, context=ctx) as r, open(\"rp3net_v0.1_d.ckpt\", \"wb\") as f:\n",
        "    f.write(r.read())\n",
        "\n",
        "print(\"Download complete!\")"
      ]
    },
